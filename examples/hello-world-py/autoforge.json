{
  "autoforge": "1.0",
  "name": "Hello Autoforge (Python)",
  "description": "Python 最小可运行脚本示例",
  "version": "1.0.0",
  "language": "python",
  "entry": "index.py",
  "category": "local",
  "env": [
    { "key": "GREETING", "label": "问候语", "default": "Hello" }
